<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score" name="ScoreLable" picking-mode="Ignore" style="align-self: center; font-size: 20px; color: rgb(255, 255, 255); -unity-text-align: upper-center; -unity-font-style: bold; top: 20px;"/>
    <ui:Label text="0" name="ScoreDisplay" parse-escape-sequences="true" picking-mode="Ignore" style="align-self: center; font-size: 20px; color: rgb(255, 255, 255); -unity-text-align: upper-center; -unity-font-style: bold; top: 10px;"/>
    <ui:Label text="FPS" name="FPSDisplay" picking-mode="Ignore" style="top: auto; align-self: flex-start; font-size: 20px; -unity-font-style: bold; color: rgb(255, 255, 255); width: 40px; position: absolute; left: auto;"/>
    <ui:Label text="0 Coins" data-source-path="" name="CoinDisplay" picking-mode="Ignore" style="-unity-font-style: bold; font-size: 20px; color: rgb(255, 255, 255); -unity-text-align: upper-right; top: auto; position: absolute; right: 0%;"/>
</ui:UXML>
